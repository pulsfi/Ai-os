# ============================================================
#  OS AI Backend — environment configuration
#  Copy to ".env" and adjust. Every value has a safe default;
#  the app boots with this file completely absent.
#  NEVER commit a real .env. NEVER store private keys here.
# ============================================================

# --- Application --------------------------------------------
APP_NAME=os-ai-backend
ENVIRONMENT=development            # development | staging | production
DEBUG=true
LOG_LEVEL=INFO                     # DEBUG | INFO | WARNING | ERROR
LOG_JSON=false                     # true = structured JSON logs (production)

# --- API -----------------------------------------------------
API_V1_PREFIX=/api/v1

# --- PostgreSQL ---------------------------------------------
DATABASE_URL=postgresql+asyncpg://osai:osai@localhost:5432/osai
DATABASE_ECHO=false

# --- Redis ---------------------------------------------------
REDIS_URL=redis://localhost:6379/0

# --- Solana (read-only; no wallets, no transactions) ---------
SOLANA_RPC_URL=https://api.mainnet-beta.solana.com
HELIUS_API_KEY=

# --- Market Intelligence (READ-ONLY market data) -------------
# Optional 5th provider (free key at birdeye.so); empty = skipped
BIRDEYE_API_KEY=
# Cache expiry per token (seconds) — the rate-limit shield
MARKET_CACHE_TTL_SECONDS=30
# Background refresh loop (persists snapshots to PostgreSQL)
MARKET_REFRESH_ENABLED=false
MARKET_REFRESH_SECONDS=300
# Minimum seconds between calls to any single provider
MARKET_PROVIDER_MIN_INTERVAL_SECONDS=1.0
# Tracked mints as a JSON list; default = SOL, JUP, BONK, WIF
# MARKET_WATCHLIST=["So11111111111111111111111111111111111111112"]

# --- AI Chat (Claude API) ------------------------------------
# Get a key at console.anthropic.com. Empty = /chat reports "not configured".
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-opus-4-8
CHAT_MAX_TOKENS=4096

# --- Bot fleet (PAPER MODE ONLY: virtual USD, no wallets, no keys) ---
BOTS_ENABLED=true
# true = every bot loop starts trading (paper) the moment the backend boots
BOTS_AUTOSTART=true
BOTS_INTERVAL_SECONDS=20
# Sniper's fallback cadence; real detection is event-driven via the stream
BOTS_SNIPER_INTERVAL_SECONDS=5
# Real-time pump.fun launch stream (PumpPortal WS); false = REST polling only
PUMPPORTAL_ENABLED=true
BOTS_USD_PER_TRADE=50
BOTS_DB_PATH=data/paper_bots.db
# Auto-write the fleet report into 12 Daily Notes/ every day
DAILY_REPORT_ENABLED=true
DAILY_REPORT_HOUR_UTC=20

# --- Obsidian vault bridge -----------------------------------
# Path to the vault root (the knowledge layer), relative to backend/.
VAULT_PATH=..
# Agents folder inside the vault (read-only source for /agents)
AGENTS_DIR=04 Agents
