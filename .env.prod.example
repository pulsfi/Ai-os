# ============================================================
#  OS AI — PRODUCTION env for the VPS stack.
#  Copy to ".env" on the server (next to docker-compose.prod.yml)
#  and fill in. NEVER commit the real .env. NEVER put a seed phrase here.
# ============================================================

# Your domain (must already point at the VPS via Namecheap DNS).
DOMAIN=osai.yourdomain.com

# --- Data providers (same keys you use locally) ---
HELIUS_API_KEY=
BIRDEYE_API_KEY=

# --- AI chat (optional) ---
ANTHROPIC_API_KEY=

# --- Alerts to your phone (optional) ---
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# --- Bot fleet (paper mode) ---
BOTS_USD_PER_TRADE=50

# --- Execution: SHIPS DISARMED. Leave false until the record is proven. ---
EXECUTION_ARMED=false
MANUAL_TRADE_MAX_USD=100
MANUAL_DAILY_BUY_LIMIT_USD=500
